{
  "name": "jikji-crosslingual",
  "version": "0.0.1",
  "note": "Cross-lingual retrieval — query and memory in DIFFERENT languages (EN↔KO, +JA/ZH/ES). Tests multilingual embedding alignment. A Korean-only specialist may underperform a native-multilingual model here; this is the real 'global' check.",
  "cases": [
    { "id": "xl-coffee-en-ko", "category": "en_query_ko_mem",
      "setup": [{ "text": "내가 좋아하는 커피는 아메리카노다" }, { "text": "나는 홍차는 거의 마시지 않는다" }],
      "query": { "need": "what coffee do I like" }, "expect": { "must_include": ["아메리카노"], "must_not_include": ["홍차"] } },
    { "id": "xl-cat-ko-en", "category": "ko_query_en_mem",
      "setup": [{ "text": "I live with a companion cat named Nabi" }, { "text": "My neighbor has a dog" }],
      "query": { "need": "내 반려동물은 무엇인가" }, "expect": { "must_include": ["Nabi"], "must_not_include": ["dog"] } },
    { "id": "xl-lang-en-ko", "category": "en_query_ko_mem",
      "setup": [{ "text": "내가 가장 좋아하는 프로그래밍 언어는 파이썬이다" }, { "text": "나는 자바는 잘 쓰지 않는다" }],
      "query": { "need": "my favorite programming language" }, "expect": { "must_include": ["파이썬"], "must_not_include": ["자바"] } },
    { "id": "xl-veg-ko-en", "category": "ko_query_en_mem",
      "setup": [{ "text": "I avoid meat and eat mostly vegetables" }, { "text": "I love grilled beef" }],
      "query": { "need": "나는 채식을 하나" }, "expect": { "must_include": ["vegetables"], "must_not_include": ["beef"] } },
    { "id": "xl-home-en-ko", "category": "en_query_ko_mem",
      "setup": [{ "text": "나는 광안리 바다가 보이는 동네에서 자랐다" }, { "text": "대학은 서울에서 다녔다" }],
      "query": { "need": "where is my hometown" }, "expect": { "must_include": ["광안리"] } },
    { "id": "xl-early-ko-en", "category": "ko_query_en_mem",
      "setup": [{ "text": "I wake up at 5am every day" }, { "text": "I often stay up late" }],
      "query": { "need": "나는 아침형 인간인가" }, "expect": { "must_include": ["5am"] } },
    { "id": "xl-ja-mem", "category": "en_query_ja_mem",
      "setup": [{ "text": "私の好きな飲み物はコーヒーです" }, { "text": "私はお茶はあまり飲みません" }],
      "query": { "need": "my favorite drink" }, "expect": { "must_include": ["コーヒー"] } },
    { "id": "xl-zh-mem", "category": "en_query_zh_mem",
      "setup": [{ "text": "我最喜欢的编程语言是Python" }, { "text": "我很少使用Java" }],
      "query": { "need": "my preferred coding language" }, "expect": { "must_include": ["Python"] } },
    { "id": "xl-es-mem", "category": "en_query_es_mem",
      "setup": [{ "text": "Vivo con un gato que se llama Nabi" }, { "text": "Mi vecino tiene un perro" }],
      "query": { "need": "do I have a cat" }, "expect": { "must_include": ["Nabi"], "must_not_include": ["perro"] } },
    { "id": "xl-market-ko-en", "category": "ko_query_en_mem",
      "setup": [{ "text": "I am allergic to peanuts and get hives" }, { "text": "I am mildly lactose intolerant" }],
      "query": { "need": "나는 견과류 알레르기가 있나" }, "expect": { "must_include": ["peanuts"], "must_not_include": ["lactose"] } }
  ]
}
