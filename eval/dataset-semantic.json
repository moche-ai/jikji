{
  "name": "jikji-korean-semantic-hard",
  "version": "0.0.1",
  "note": "의미적 하드셋 — 질의와 정답이 뜻은 같으나 표면 토큰이 거의 겹치지 않음(패러프레이즈·동의·상위어). lexical/BM25 는 실패하고 의미 임베딩(KURE-v1)만 top-1 을 맞히도록 설계. 스캐폴드 대비 KURE-v1 개선율 측정용.",
  "cases": [
    { "id": "sem-drink", "category": "패러프레이즈",
      "setup": [{ "text": "커피는 하루를 여는 나의 필수품이다" }],
      "query": { "need": "아침에 즐겨 마시는 음료" },
      "expect": { "must_include": ["커피"] } },
    { "id": "sem-remote", "category": "패러프레이즈",
      "setup": [{ "text": "집에서 일할 때 훨씬 더 집중이 잘 된다" }],
      "query": { "need": "재택근무 선호 여부" },
      "expect": { "must_include": ["집에서"] } },
    { "id": "sem-cat", "category": "동의어",
      "setup": [{ "text": "반려묘 나비와 함께 살고 있다" }],
      "query": { "need": "고양이를 키우나요" },
      "expect": { "must_include": ["나비"] } },
    { "id": "sem-exercise", "category": "상위어",
      "setup": [{ "text": "주말마다 헬스장에서 땀을 흘리며 근력을 기른다" }],
      "query": { "need": "운동을 즐기는지" },
      "expect": { "must_include": ["헬스장"] } },
    { "id": "sem-veg", "category": "패러프레이즈",
      "setup": [{ "text": "고기는 먹지 않고 야채와 두부 위주로 식사한다" }],
      "query": { "need": "채식주의자인가" },
      "expect": { "must_include": ["야채"] } },
    { "id": "sem-early", "category": "패러프레이즈",
      "setup": [{ "text": "새벽 다섯 시에 눈을 떠 하루를 시작한다" }],
      "query": { "need": "일찍 일어나는 편인가" },
      "expect": { "must_include": ["새벽"] } },
    { "id": "sem-music", "category": "상위어",
      "setup": [{ "text": "퇴근 후에는 재즈 엘피판을 턴테이블로 듣는다" }],
      "query": { "need": "음악 감상 취미" },
      "expect": { "must_include": ["재즈"] } },
    { "id": "sem-car", "category": "상위어",
      "setup": [{ "text": "빨간색 아반떼를 몰고 출퇴근한다" }],
      "query": { "need": "자동차를 소유하고 있는지" },
      "expect": { "must_include": ["아반떼"] } },
    { "id": "sem-married", "category": "패러프레이즈",
      "setup": [{ "text": "아내와 함께 아늑한 신혼집을 꾸몄다" }],
      "query": { "need": "혼인 여부" },
      "expect": { "must_include": ["아내"] } },
    { "id": "sem-allergy", "category": "패러프레이즈",
      "setup": [{ "text": "땅콩이 들어간 음식을 먹으면 두드러기가 올라온다" }],
      "query": { "need": "견과류 알레르기가 있는지" },
      "expect": { "must_include": ["땅콩"] } },
    { "id": "sem-lang", "category": "상위어",
      "setup": [{ "text": "파이썬으로 데이터 파이프라인을 짜는 걸 가장 즐긴다" }],
      "query": { "need": "선호하는 프로그래밍 언어" },
      "expect": { "must_include": ["파이썬"] } },
    { "id": "sem-city", "category": "패러프레이즈",
      "setup": [{ "text": "광안리 바다가 보이는 동네에서 자랐다" }],
      "query": { "need": "고향이 어디인지" },
      "expect": { "must_include": ["광안리"] } }
  ]
}
