{
  "name": "jikji-korean-hard-discriminative",
  "version": "0.0.1",
  "note": "임베딩 A/B 변별셋 — 존칭 해소·동명이인·이중부정·관용구·은어·완곡·축약. 각 케이스에 '같은 주제 하드 distractor'를 넣어 정답이 유사 오답을 제치고 top-1 이 되게(한국어 특화 모델 변별).",
  "cases": [
    { "id": "h-honor-name", "category": "존칭해소",
      "setup": [{ "text": "김 부장님은 결재를 오후에 하신다" }, { "text": "박 부장님은 결재를 오전에 하신다" }],
      "query": { "need": "김 부장이 결재하는 시간대" }, "expect": { "must_include": ["오후"], "must_not_include": ["오전"] } },
    { "id": "h-homonym-role", "category": "동명이인",
      "setup": [{ "text": "개발팀 이수진은 리액트 프론트엔드를 담당한다" }, { "text": "디자인팀 이수진은 로고와 브랜딩을 담당한다" }],
      "query": { "need": "개발팀 이수진이 맡은 일" }, "expect": { "must_include": ["리액트"], "must_not_include": ["로고"] } },
    { "id": "h-double-neg", "category": "이중부정",
      "setup": [{ "text": "회의를 취소하지 않기로 최종 결정했다" }, { "text": "회의 장소만 회의실로 변경했다" }],
      "query": { "need": "회의는 예정대로 열리나" }, "expect": { "must_include": ["취소하지 않"] } },
    { "id": "h-slang-value", "category": "은어",
      "setup": [{ "text": "그 국밥집은 가성비가 갑이라 자주 간다" }, { "text": "그 국밥집은 주차가 불편하다" }],
      "query": { "need": "그 가게가 가격 대비 만족스러운가" }, "expect": { "must_include": ["가성비"] } },
    { "id": "h-idiom-network", "category": "관용구",
      "setup": [{ "text": "그는 발이 넓어서 업계 인맥이 두텁다" }, { "text": "그는 손이 커서 씀씀이가 크다" }],
      "query": { "need": "그는 아는 사람이 많은 편인가" }, "expect": { "must_include": ["발이 넓"], "must_not_include": ["손이 커"] } },
    { "id": "h-hanja-native", "category": "한자어동의",
      "setup": [{ "text": "매일 새벽 조깅으로 건강을 관리한다" }, { "text": "가끔 주말 등산으로 스트레스를 푼다" }],
      "query": { "need": "규칙적으로 하는 신체 활동" }, "expect": { "must_include": ["조깅"], "must_not_include": ["등산"] } },
    { "id": "h-abbrev", "category": "축약신조어",
      "setup": [{ "text": "내 점메추는 언제나 김치찌개다" }, { "text": "내 저메추는 주로 파스타다" }],
      "query": { "need": "점심 메뉴로 추천하는 것" }, "expect": { "must_include": ["김치찌개"], "must_not_include": ["파스타"] } },
    { "id": "h-reltime", "category": "상대시간",
      "setup": [{ "text": "다다음 주에 부산으로 출장을 간다" }, { "text": "다음 주에는 하루 재택근무를 한다" }],
      "query": { "need": "2주 뒤에 잡힌 일정" }, "expect": { "must_include": ["다다음 주"], "must_not_include": ["재택"] } },
    { "id": "h-honor-rel", "category": "존대관계",
      "setup": [{ "text": "사장님을 모시고 중요한 미팅에 참석했다" }, { "text": "동기와 가볍게 점심을 먹었다" }],
      "query": { "need": "윗사람과 함께한 업무 자리" }, "expect": { "must_include": ["사장님을 모시"] } },
    { "id": "h-pref-neg", "category": "완곡선호",
      "setup": [{ "text": "번잡한 도심보다 한적한 교외를 선호한다" }, { "text": "활기찬 번화가의 분위기를 좋아한다" }],
      "query": { "need": "조용한 동네를 좋아하는 편인가" }, "expect": { "must_include": ["한적한 교외"], "must_not_include": ["번화가"] } },
    { "id": "h-euphem", "category": "완곡감정",
      "setup": [{ "text": "그 제안은 다시 한번 신중히 생각해봐야겠다" }, { "text": "그 제안은 당장이라도 진행하고 싶다" }],
      "query": { "need": "제안에 대해 유보적인 태도인가" }, "expect": { "must_include": ["다시 한번"], "must_not_include": ["당장"] } },
    { "id": "h-slang2", "category": "은어",
      "setup": [{ "text": "이번 신제품 발표는 완전 갓벽이라는 평가를 받았다" }, { "text": "지난 발표는 준비가 부족해 아쉬웠다" }],
      "query": { "need": "매우 성공적이었던 발표" }, "expect": { "must_include": ["갓벽"], "must_not_include": ["아쉬"] } },
    { "id": "h-honor-verb", "category": "존대동사",
      "setup": [{ "text": "할머니께서 손수 김장을 담그셨다" }, { "text": "이모는 마트에서 반찬을 사오셨다" }],
      "query": { "need": "직접 김치를 만드신 분" }, "expect": { "must_include": ["할머니"], "must_not_include": ["이모"] } },
    { "id": "h-neg-degree", "category": "정도부정",
      "setup": [{ "text": "이 떡볶이는 안 매운 건 아니지만 먹을 만하다" }, { "text": "저 파스타는 전혀 맵지 않고 담백하다" }],
      "query": { "need": "약간은 매운 편인 음식" }, "expect": { "must_include": ["안 매운 건 아니"] } }
  ]
}
